<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.friday.assistant"
    android:versionCode="6"
    android:versionName="3.2.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="36" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SET_ALARM" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <permission
        android:name="com.friday.assistant.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.friday.assistant.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Friday" >

        <!-- ═══ Main Activity ═══ -->
        <activity
            android:name="com.friday.assistant.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ═══ Assistant Activity — handles the ASSIST intent ═══ -->
        <activity
            android:name="com.friday.assistant.AssistantActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:taskAffinity="com.friday.assistant.assistant"
            android:theme="@style/Theme.Friday.Assistant" >
            <intent-filter>
                <action android:name="android.intent.action.ASSIST" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- ═══ Onboarding Activity ═══ -->
        <activity
            android:name="com.friday.assistant.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ═══ Settings Activity ═══ -->
        <activity
            android:name="com.friday.assistant.SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings"
            android:screenOrientation="portrait" />

        <!-- ═══ Custom Commands Activity ═══ -->
        <activity
            android:name="com.friday.assistant.CustomCommandsActivity"
            android:exported="false"
            android:label="Custom Commands"
            android:screenOrientation="portrait" />

        <!-- ═══ Voice Interaction Service ═══ -->
        <!--
             This is the bootstrap point that Android uses to recognise Friday
             as a valid assistant. Without it, Friday never appears in the
             default assistant picker.
        -->
        <service
            android:name="com.friday.assistant.service.FridayVoiceInteractionService"
            android:exported="true"
            android:label="Friday"
            android:permission="android.permission.BIND_VOICE_INTERACTION" >
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>

            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/voice_interaction" />
        </service>

        <!-- ═══ Voice Interaction Session Service ═══ -->
        <!--
             REQUIRED: Android will not show Friday in the assistant picker
             unless both VoiceInteractionService AND VoiceInteractionSessionService
             are declared and properly linked via voice_interaction.xml.
        -->
        <service
            android:name="com.friday.assistant.service.FridaySessionService"
            android:exported="true"
            android:label="Friday Session"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />

        <!-- ═══ Recognition Service ═══ -->
        <!--
             Required by voice_interaction.xml's recognitionService attribute.
             Delegates to the device's built-in Google Speech Services.
        -->
        <service
            android:name="com.friday.assistant.service.FridayRecognitionService"
            android:exported="true"
            android:label="Friday Speech Recognition"
            android:permission="android.permission.BIND_VOICE_INTERACTION" >
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>

            <meta-data
                android:name="android.speech"
                android:resource="@xml/voice_interaction" />
        </service>

        <!-- ═══ Foreground Service ═══ -->
        <service
            android:name="com.friday.assistant.service.FridayForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone|mediaPlayback"
            android:stopWithTask="false" />

        <!-- ═══ Peek Overlay Service ═══ -->
        <service
            android:name="com.friday.assistant.service.PeekOverlayService"
            android:exported="false" />

        <!-- ═══ Boot Receiver ═══ -->
        <receiver
            android:name="com.friday.assistant.service.BootReceiver"
            android:enabled="true"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.friday.assistant.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>