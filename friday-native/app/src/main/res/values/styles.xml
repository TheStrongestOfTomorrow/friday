<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Friday" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_purple</item>
        <item name="colorPrimaryDark">@color/brand_purple_dark</item>
        <item name="colorAccent">@color/brand_purple_light</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialButtonStyle">@style/Widget.Friday.Button</item>
        <item name="editTextStyle">@style/Widget.Friday.EditText</item>
        <item name="switchStyle">@style/Widget.Friday.Switch</item>
    </style>

    <style name="Widget.Friday.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/brand_purple</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Widget.Friday.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/divider</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/transparent</item>
    </style>

    <style name="Widget.Friday.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/danger_red</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Friday.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:padding">@dimen/margin_md</item>
        <item name="android:textSize">@dimen/text_md</item>
    </style>

    <style name="Widget.Friday.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="trackTint">@color/toggle_track_off</item>
        <item name="thumbTint">@color/text_secondary</item>
        <item name="android:thumbTint">@color/toggle_thumb_selector</item>
    </style>

    <style name="Widget.Friday.Card" parent="">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">@dimen/margin_md</item>
    </style>

    <style name="FridayTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_xxl</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>

    <style name="FridaySubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="FridayBody">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="FridayCaption">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">@dimen/text_sm</item>
    </style>

    <style name="OnboardTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_xxl</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="OnboardSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:gravity">center</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Assistant Activity theme — translucent, immersive, slides up -->
    <style name="Theme.Friday.Assistant" parent="Theme.Friday">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.InputMethod</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
