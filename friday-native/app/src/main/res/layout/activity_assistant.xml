<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/assistantRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/bg_primary"
    android:padding="24dp">

    <!-- Close button -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="end"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Close"
        android:tint="@color/text_secondary" />

    <!-- Spacer -->
    <View
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Status -->
    <TextView
        android:id="@+id/tvAssistantStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hi! I'm Friday. How can I help?"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:paddingBottom="16dp" />

    <!-- Transcription -->
    <TextView
        android:id="@+id/tvAssistantTranscription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="visible"
        android:paddingBottom="24dp"
        android:maxLines="3"
        android:ellipsize="end" />

    <!-- Wave indicator -->
    <LinearLayout
        android:id="@+id/waveIndicator"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone">

        <View android:layout_width="3dp" android:layout_height="8dp"
            android:layout_margin="2dp" android:background="@color/brand_purple" />
        <View android:layout_width="3dp" android:layout_height="16dp"
            android:layout_margin="2dp" android:background="@color/brand_purple" />
        <View android:layout_width="3dp" android:layout_height="24dp"
            android:layout_margin="2dp" android:background="@color/brand_purple" />
        <View android:layout_width="3dp" android:layout_height="16dp"
            android:layout_margin="2dp" android:background="@color/brand_purple" />
        <View android:layout_width="3dp" android:layout_height="8dp"
            android:layout_margin="2dp" android:background="@color/brand_purple" />
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/assistantProgressBar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:indeterminateTint="@color/brand_purple" />

    <!-- Mic button -->
    <ImageButton
        android:id="@+id/btnAssistantMic"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_mic"
        android:background="@drawable/bg_listen_button"
        android:contentDescription="Listen"
        android:scaleType="centerInside"
        android:padding="20dp" />

    <!-- Spacer -->
    <View
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
