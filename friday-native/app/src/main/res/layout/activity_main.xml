<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="@dimen/margin_md">

    <!-- Settings gear icon button — top right -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="@string/title_settings"
        android:background="@drawable/bg_button_ghost"
        android:padding="8dp"
        android:tint="@color/text_secondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/statusCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_lg"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/btnSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/margin_lg">

            <!-- Status dot -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="@dimen/status_dot_size"
                android:layout_height="@dimen/status_dot_size"
                android:background="@drawable/bg_sample_dot_filled"
                android:backgroundTint="@color/text_muted" />

            <!-- Status label -->
            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_sm"
                android:text="@string/status_idle"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_lg"
                android:fontFamily="sans-serif-medium" />

            <!-- Status description -->
            <TextView
                android:id="@+id/statusDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/status_idle_desc"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                android:gravity="center" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Transcription card — initially GONE -->
    <androidx.cardview.widget.CardView
        android:id="@+id/transcriptionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_sm"
        android:visibility="gone"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/statusCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <TextView
            android:id="@+id/transcriptionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/margin_md"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            tools:text="Hello Friday, what's the weather today?" />

    </androidx.cardview.widget.CardView>

    <!-- Large circular listen button -->
    <ImageButton
        android:id="@+id/btnListen"
        android:layout_width="@dimen/listen_button_size"
        android:layout_height="@dimen/listen_button_size"
        android:src="@drawable/ic_mic"
        android:contentDescription="@string/btn_listen"
        android:background="@drawable/bg_listen_button"
        android:padding="0dp"
        android:scaleType="centerInside"
        android:tint="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@id/transcriptionCard"
        app:layout_constraintBottom_toTopOf="@id/listenLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <!-- Listen label -->
    <TextView
        android:id="@+id/listenLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_lg"
        android:text="@string/btn_listen"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_sm"
        app:layout_constraintBottom_toTopOf="@id/quickActionsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Quick actions row -->
    <LinearLayout
        android:id="@+id/quickActionsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnTestDuck"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_sm"
            android:text="Test Duck"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_button_ghost"
            android:textSize="@dimen/text_sm" />

        <Button
            android:id="@+id/btnTestResume"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/margin_sm"
            android:text="Test Resume"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_button_ghost"
            android:textSize="@dimen/text_sm" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
